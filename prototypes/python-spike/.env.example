# Copy to .env and fill in. .env is gitignored.
#
# RSI session cookie. To capture: open DevTools on robertsspaceindustries.com
# while logged in -> Application -> Cookies -> copy the value of `Rsi-Token`.
# This is *your* session, treat it like a password.
RSI_TOKEN=

# Optional: override Game.log location. Defaults to the standard install path.
# STARSTATS_GAMELOG=C:\Program Files\Roberts Space Industries\StarCitizen\LIVE\Game.log

# Optional: override SQLite database path. Defaults to user data dir.
# STARSTATS_DB=
