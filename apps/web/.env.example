# StarStats web — local dev configuration
#
# Copy to `.env.local` (gitignored — Next.js loads it automatically).
# Production values are set by your container orchestrator.

# Where the Next.js server-side fetches reach the API. Server-only
# (no NEXT_PUBLIC_ prefix) — the browser never talks to the API
# directly; all calls funnel through the Next.js server.
#
# Local dev: point at a locally-running starstats-server.
# Production: internal service hostname, e.g. http://starstats-api:8080
STARSTATS_API_URL=http://localhost:8080

# ---- Telemetry (optional) ------------------------------------------
# OpenTelemetry trace exporter. Empty/unset disables tracing on boot
# (see src/instrumentation.ts). Production points at the homelab
# OTel collector at http://otel-collector:4317 (gRPC).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=starstats-web

# ---- Error reporting (optional, GlitchTip via Sentry protocol) -----
# Project DSN from the GlitchTip UI. Empty/unset means errors render
# the user-facing error.tsx page but aren't shipped to GlitchTip.
# `GLITCHTIP_RELEASE` is purely for grouping in the GlitchTip UI.
# GLITCHTIP_DSN=https://<project-key>@stats-errors.example.com/<project-id>
# GLITCHTIP_RELEASE=dev
