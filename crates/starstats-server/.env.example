# StarStats API server — local dev configuration
#
# Copy to `.env` (gitignored) and adjust for your local setup. The
# server will pick this up via dotenvy if invoked via cargo with the
# repo root as cwd, or you can `source` it manually.
#
# Production deployment uses Docker secrets at /run/secrets/* and
# inline env vars set in voyager-compose.yml — see
# docs/HOMELAB-INTEGRATION.md for the full set.

# ---- Bind ---------------------------------------------------------
# Local dev defaults to all interfaces on 8080. The Dockerfile keeps
# the same default.
STARSTATS_BIND=0.0.0.0:8080

# ---- Database -----------------------------------------------------
# Either supply a full DATABASE_URL (preferred for local dev), or
# the STARSTATS_DB_* parts and the server will compose the URL.
DATABASE_URL=postgres://starstats_app:devpassword@localhost:5432/starstats?sslmode=disable

# Compose-style alternative (uncomment if you prefer parts):
# STARSTATS_DB_HOST=localhost
# STARSTATS_DB_PORT=5432
# STARSTATS_DB_USER=starstats_app
# STARSTATS_DB_NAME=starstats
# STARSTATS_DB_PASSWORD=devpassword
# Or read the password from a file (production pattern):
# STARSTATS_DB_PASSWORD_FILE=/run/secrets/starstats_db_password

# ---- JWT issuer ---------------------------------------------------
# Required. Must match the public origin of the web app — desktop
# clients discover the JWKS at $STARSTATS_JWT_ISSUER/.well-known/jwks.json.
STARSTATS_JWT_ISSUER=http://localhost:3000

# Audience baked into every minted token's `aud` claim. Default is fine.
STARSTATS_JWT_AUDIENCE=starstats

# Path to the RSA private key PEM. Auto-generated on first boot if
# absent. Default in the Dockerfile is /var/lib/starstats/jwt-key.pem;
# for local dev anywhere writable works.
STARSTATS_JWT_KEY_FILE=./.dev-jwt-key.pem

# ---- Logging ------------------------------------------------------
# Standard tracing-subscriber filter. The default in code is
# "info,starstats=debug,sqlx=warn,tower_http=debug" if unset.
# RUST_LOG=info,starstats=debug,sqlx=warn
